num_passwords = get_int("Quante password generare? ", 1, 50)
separator_choice = input("Separatore per token multi-carattere nell'output (Invio per nessuno): ")


def build_single(counts):
    parts = []

    def draw(pool, k):
        if k <= 0:
            return []
        if no_repeat:
            if k > len(pool):
                return random.choices(pool, k=k)
            return random.sample(pool, k)
        return random.choices(pool, k=k)

    parts += draw(letters_upper, counts["upper"])
    parts += draw(letters_lower, counts["lower"])
    parts += draw(numbers, counts["numbers"])
    parts += draw(symbols_standard, counts["sym_std"])
    parts += draw(symbols_brackets, counts["sym_bra"])
    parts += draw(linux_syntax, counts["linux"])

    random.shuffle(parts)
    return separator_choice.join(parts)


