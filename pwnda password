def get_int(prompt, min_v=0, max_v=999):
    while True:
        try:
            v = int(input(prompt))
            if v < min_v or v > max_v:
                print(f"Inserisci un intero compreso tra {min_v} e {max_v}.")
                continue
            return v
        except ValueError:
            print("Inserisci un valore intero valido.")


def yes_no(prompt):
    while True:
        r = input(prompt + " (y/n): ").strip().lower()
        if r in ("y", "yes"):
            return True
        if r in ("n", "no"):
            return False


def print_progress_bar(iteration, total, prefix='', suffix='', length=30):
    """Disegna una barra di caricamento animata nel terminale."""
    percent = f"{100 * (iteration / float(total)):.1f}"
    filled_length = int(length * iteration // total)
    bar = '‚Ėą' * filled_length + '-' * (length - filled_length)
    print(f'\r{prefix} |{bar}| {percent}% {suffix}', end='', flush=True)
    if iteration == total:
        print()


